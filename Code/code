# Annual data from report (2020-2025)
annual_data = pd.DataFrame({
    'Year': [2020, 2021, 2022, 2023, 2024, 2025],
    'Revenue_Billion': [33.01, 38.66, 43.00, 45.75, 47.06, 47.94],
    'Ad_Spend_Billion': [2.80, 3.50, 4.00, 5.00, 5.20, 5.40],
    'Digital_Pct': [30, 45, 55, 60, 65, 70],
    'TV_Pct': [70, 55, 45, 40, 35, 30],
    'Ad_to_Rev_Pct': [8.5, 9.1, 9.3, 10.9, 11.1, 11.3]
})

# Quarterly data (2020-2025) for ARIMA
np.random.seed(42)
quarters = pd.date_range('2020-01-01', '2025-12-31', freq='Q')
n_quarters = len(quarters)

# Generate realistic quarterly revenue with seasonality (Q2/Q3 peaks)
trend = np.linspace(33.01/4, 47.94/4, n_quarters)  # Convert annual to quarterly avg
seasonality = np.array([-0.4, 0.6, 0.5, -0.7] * (n_quarters // 4 + 1))[:n_quarters]
noise = np.random.normal(0, 0.15, n_quarters)

quarterly_revenue = trend + seasonality + noise

quarterly_data = pd.DataFrame({
    'Date': quarters,
    'Quarter': [f'Q{q.quarter} {q.year}' for q in quarters],
    'Revenue_Billion': np.round(quarterly_revenue, 2)
})

# Advertising spend by channel (quarterly)
np.random.seed(42)
quarterly_ad_data = pd.DataFrame({
    'Date': quarters,
    'TV_Spend_Million': np.random.uniform(600, 900, n_quarters),
    'Digital_Spend_Million': np.random.uniform(400, 1000, n_quarters),
    'Social_Spend_Million': np.random.uniform(200, 700, n_quarters)
})

# Ensure realistic progression (digital increasing over time)
for i in range(n_quarters):
    quarterly_ad_data.loc[i, 'Digital_Spend_Million'] = 400 + (i / n_quarters) * 600
    quarterly_ad_data.loc[i, 'Social_Spend_Million'] = 200 + (i / n_quarters) * 500
    quarterly_ad_data.loc[i, 'TV_Spend_Million'] = 900 - (i / n_quarters) * 300

quarterly_ad_data['Total_Spend_Million'] = quarterly_ad_data[['TV_Spend_Million', 'Digital_Spend_Million', 'Social_Spend_Million']].sum(axis=1)

# Combine revenue and ad spend
model_data = quarterly_data.copy()
model_data['TV_Spend_Million'] = quarterly_ad_data['TV_Spend_Million']
model_data['Digital_Spend_Million'] = quarterly_ad_data['Digital_Spend_Million']
model_data['Social_Spend_Million'] = quarterly_ad_data['Social_Spend_Million']

print("\n" + "="*70)
print("SECTION 1: DATA OVERVIEW")
print("="*70)
print("\nAnnual Data (2020-2025):")
