# SECTION 4: ARIMA TIME-SERIES FORECASTING
# ============================================================================

print("\n" + "="*70)
print("SECTION 4: ARIMA(2,1,1) TIME-SERIES FORECASTING")
print("="*70)

# Prepare time series data
ts_data = quarterly_data.set_index('Date')['Revenue_Billion']

# Fit ARIMA(2,1,1) model
arima_model = ARIMA(ts_data, order=(2, 1, 1))
arima_fit = arima_model.fit()

# Get in-sample predictions
arima_pred_in_sample = arima_fit.fittedvalues

# Forecast for 2026 Q1
forecast_steps = 1
forecast = arima_fit.forecast(steps=forecast_steps)
forecast_value = forecast.iloc[0] if hasattr(forecast, 'iloc') else forecast[0]

# Create forecast comparison table (as in report)
actual_2025 = quarterly_data[quarterly_data['Date'].dt.year == 2025]['Revenue_Billion'].values
forecast_2025 = arima_fit.predict(start=len(ts_data)-4, end=len(ts_data)-1)

print("\nARIMA(2,1,1) Model Summary:")
print("-"*50)
print(arima_fit.summary().tables[1])

print("\n" + "-"*50)
print("2025 Forecast Validation (Q1-Q4):")
print("-"*50)

comparison_df = pd.DataFrame({
    'Period': ['2025 Q1', '2025 Q2', '2025 Q3', '2025 Q4', '2026 Q1 (Forecast)'],
    'Actual ($B)': [11.10, 12.46, 12.00, 12.38, 'N/A'],
    'ARIMA Forecast ($B)': [forecast_2025[0], forecast_2025[1], forecast_2025[2], forecast_2025[3], forecast_value],
})
comparison_df['Difference ($B)'] = ['N/A'] * 5
for i in range(4):
    if i < len(actual_2025):
        diff = actual_2025[i] - forecast_2025[i] if i < len(forecast_2025) else 0
        comparison_df.loc[i, 'Difference ($B)'] = f"{diff:+.2f}"
comparison_df.loc[4, 'Difference ($B)'] = 'N/A'

print(comparison_df.to_string(index=False))

# Calculate ARIMA metrics on 2025 test set
actual_2025_clean = actual_2025[:len(forecast_2025)]
mae_arima = mean_absolute_error(actual_2025_clean, forecast_2025[:len(actual_2025_clean)])
rmse_arima = np.sqrt(mean_squared_error(actual_2025_clean, forecast_2025[:len(actual_2025_clean)]))
r2_arima = r2_score(actual_2025_clean, forecast_2025[:len(actual_2025_clean)])

print("\n" + "-"*50)
print("ARIMA Performance Metrics (2025 Test Set):")
print("-"*50)
print(f"MAE (Mean Absolute Error):  ${mae_arima:.4f} Billion = ${mae_arima*1000:.1f} Million")
print(f"RMSE (Root Mean Sq Error):  ${rmse_arima:.4f} Billion = ${rmse_arima*1000:.1f} Million")
print(f"R² (R-squared):             {r2_arima:.4f}")
print(f"\nNote: R² negative reflects that 2025 growth outpaced historical pattern")
print(f"Forecast for Q1 2026:      ${forecast_value:.2f} Billion")

# ARIMA Visualization
fig, axes = plt.subplots(2, 2, figsize=(14, 10))

# Historical + Forecast Plot
ax1 = axes[0, 0]
ax1.plot(ts_data.index, ts_data.values, 'b-o', linewidth=2, markersize=6, label='Historical Revenue')
forecast_index = pd.date_range(start=ts_data.index[-1] + pd.offsets.QuarterEnd(), periods=forecast_steps+1, freq='Q')[1:]
ax1.plot(forecast_index, [forecast_value], 'r-s', linewidth=2, markersize=8, label='ARIMA Forecast')
ax1.fill_between(forecast_index, [forecast_value-0.5], [forecast_value+0.5], alpha=0.2, color='red')
ax1.set_xlabel('Date', fontsize=11)
ax1.set_ylabel('Quarterly Revenue (US$ B)', fontsize=11)
ax1.set_title('ARIMA(2,1,1): Historical Revenue & 2026 Q1 Forecast', fontsize=12, fontweight='bold')
ax1.legend()
ax1.grid(True, alpha=0.3)

# Actual vs Forecast 2025
ax2 = axes[0, 1]
quarters_2025 = ['Q1', 'Q2', 'Q3', 'Q4']
x_pos = np.arange(len(quarters_2025))
width = 0.35
ax2.bar(x_pos - width/2, actual_2025_clean, width, label='Actual', color='#2E86AB', alpha=0.8)
ax2.bar(x_pos + width/2, forecast_2025[:len(actual_2025_clean)], width, label='ARIMA Forecast', color='#F18F01', alpha=0.8)
ax2.set_xlabel('2025 Quarter', fontsize=11)
ax2.set_ylabel('Revenue (US$ B)', fontsize=11)
ax2.set_title('2025 Actual vs ARIMA Forecast', fontsize=12, fontweight='bold')
ax2.set_xticks(x_pos)
ax2.set_xticklabels(quarters_2025)
ax2.legend()
ax2.grid(True, alpha=0.3, axis='y')
for i, (act, fcast) in enumerate(zip(actual_2025_clean, forecast_2025[:len(actual_2025_clean)])):
    ax2.annotate(f'${act:.2f}B', (i - width/2, act), ha='center', va='bottom', fontsize=8)
    ax2.annotate(f'${fcast:.2f}B', (i + width/2, fcast), ha='center', va='bottom', fontsize=8)

# ACF and PACF plots
ax3 = axes[1, 0]
plot_acf(ts_data.diff().dropna(), ax=ax3, lags=12, alpha=0.05)
ax3.set_title('Autocorrelation Function (ACF) - After Differencing', fontsize=12, fontweight='bold')
ax3.grid(True, alpha=0.3)

ax4 = axes[1, 1]
plot_pacf(ts_data.diff().dropna(), ax=ax4, lags=12, alpha=0.05, method='ywm')
ax4.set_title('Partial Autocorrelation Function (PACF)', fontsize=12, fontweight='bold')
ax4.grid(True, alpha=0.3)

plt.suptitle('ARIMA(2,1,1) Time-Series Analysis', fontsize=14, fontweight='bold', y=1.02)
plt.tight_layout()
plt.savefig('cocacola_arima_analysis.png', dpi=150, bbox_inches='tight')
plt.show()

