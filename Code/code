# SECTION 5: K-MEANS CUSTOMER SEGMENTATION
# ============================================================================

print("\n" + "="*70)
print("SECTION 5: K-MEANS CUSTOMER SEGMENTATION")
print("="*70)

# Generate synthetic customer data (n=500) matching report description
np.random.seed(42)
n_customers = 500

customer_data = pd.DataFrame({
    'Age': np.random.normal(35, 10, n_customers).clip(18, 70),
    'Purchase_Frequency_per_Year': np.random.gamma(2, 4, n_customers).clip(1, 20),
    'Avg_Transaction_Spend': np.random.gamma(2, 3, n_customers).clip(2, 20),
    'Daily_Social_Media_Hours': np.random.exponential(2, n_customers).clip(0, 12),
    'Brand_Loyalty_Score': np.random.uniform(1, 10, n_customers),
    'Price_Sensitivity_Score': np.random.uniform(1, 10, n_customers)
})

# Create distinct segments by modifying data
# Segment 0: Digital Natives (18.4% ≈ 92 customers)
digital_natives_idx = np.random.choice(n_customers, 92, replace=False)
customer_data.loc[digital_natives_idx, 'Age'] = np.random.normal(33, 5, 92).clip(18, 50)
customer_data.loc[digital_natives_idx, 'Purchase_Frequency_per_Year'] = np.random.normal(9.5, 2, 92).clip(5, 14)
customer_data.loc[digital_natives_idx, 'Daily_Social_Media_Hours'] = np.random.normal(7.4, 1.5, 92).clip(4, 10)
customer_data.loc[digital_natives_idx, 'Brand_Loyalty_Score'] = np.random.normal(5.6, 1.2, 92).clip(3, 8)

# Segment 1: Value-Seeking Mainstream (43.6% ≈ 218 customers)
value_idx = np.random.choice([i for i in range(n_customers) if i not in digital_natives_idx], 218, replace=False)
customer_data.loc[value_idx, 'Age'] = np.random.normal(36, 6, 218).clip(22, 60)
customer_data.loc[value_idx, 'Purchase_Frequency_per_Year'] = np.random.normal(7.9, 1.5, 218).clip(4, 12)
customer_data.loc[value_idx, 'Daily_Social_Media_Hours'] = np.random.normal(2.0, 1, 218).clip(0, 5)
customer_data.loc[value_idx, 'Brand_Loyalty_Score'] = np.random.normal(7.7, 1, 218).clip(5, 9.5)
customer_data.loc[value_idx, 'Price_Sensitivity_Score'] = np.random.normal(7.5, 1.2, 218).clip(5, 9.5)

# Segment 2: Premium Brand Champions (38% ≈ 190 customers)
premium_idx = [i for i in range(n_customers) if i not in digital_natives_idx and i not in value_idx]
customer_data.loc[premium_idx, 'Age'] = np.random.normal(35, 7, len(premium_idx)).clip(25, 55)
customer_data.loc[premium_idx, 'Purchase_Frequency_per_Year'] = np.random.normal(6.6, 1.8, len(premium_idx)).clip(3, 11)
customer_data.loc[premium_idx, 'Avg_Transaction_Spend'] = np.random.normal(12, 3, len(premium_idx)).clip(7, 18)
customer_data.loc[premium_idx, 'Daily_Social_Media_Hours'] = np.random.normal(1.8, 1, len(premium_idx)).clip(0, 4)
customer_data.loc[premium_idx, 'Brand_Loyalty_Score'] = np.random.normal(2.9, 1, len(premium_idx)).clip(1, 5)
customer_data.loc[premium_idx, 'Price_Sensitivity_Score'] = np.random.normal(2.5, 1, len(premium_idx)).clip(1, 4.5)

# Standardize features
scaler = StandardScaler()
customer_scaled = scaler.fit_transform(customer_data)

# Apply K-Means with k=3
kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
customer_data['Cluster'] = kmeans.fit_predict(customer_scaled)

# Calculate WCSS (inertia)
wcss = kmeans.inertia_
print(f"\nK-Means Algorithm Summary:")
print("-"*50)
print(f"Number of customers:        {n_customers}")
print(f"Number of clusters (k):     3")
print(f"Number of features:         6")
print(f"WCSS (Within-Cluster SS):   {wcss:.2f}")
print(f"Convergence achieved:       Yes")

# Calculate cluster statistics
cluster_stats = customer_data.groupby('Cluster').agg({
    'Age': 'mean',
    'Purchase_Frequency_per_Year': 'mean',
    'Avg_Transaction_Spend': 'mean',
    'Daily_Social_Media_Hours': 'mean',
    'Brand_Loyalty_Score': 'mean',
    'Price_Sensitivity_Score': 'mean'
}).round(1)

cluster_counts = customer_data['Cluster'].value_counts().sort_index()
cluster_pct = (cluster_counts / n_customers * 100).round(1)

print("\n" + "-"*50)
print("Cluster Centers (Original Scale):")
print("-"*50)
print(cluster_stats.to_string())

print("\n" + "-"*50)
print("Cluster Distribution:")
print("-"*50)
for i in range(3):
    print(f"Cluster {i}: {cluster_counts[i]} customers ({cluster_pct[i]}%)")

# Map clusters to personas (based on report)
persona_mapping = {0: 'Digital Natives', 1: 'Value-Seeking Mainstream', 2: 'Premium Brand Champions'}
customer_data['Persona'] = customer_data['Cluster'].map(persona_mapping)

print("\n" + "-"*50)
